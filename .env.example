# ===== SmartParking Frontend Environment =====
# Sao chép file này thành .env và điền giá trị thật vào
# Copy this file to .env and fill in the actual values
# KHÔNG commit file .env lên GitHub / DO NOT commit .env to GitHub

# Backend API URL
VITE_API_BASE_URL=http://localhost:8080/api/v1

# Google OAuth2 Client ID
# Lấy từ: https://console.cloud.google.com/ → APIs & Services → Credentials → Create OAuth 2.0 Client ID
# Chọn Application type: Web application
# Authorized JavaScript origins: http://localhost:5173
# Authorized redirect URIs: http://localhost:5173
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com

# Facebook App ID
# Lấy từ: https://developers.facebook.com/ → Create App → Settings → Basic → App ID
VITE_FACEBOOK_APP_ID=YOUR_FACEBOOK_APP_ID

# Cấu hình Cloudinary (upload ảnh check-in/out)
# Lấy từ: https://cloudinary.com/ → Dashboard → Cloud name
VITE_CLOUDINARY_CLOUD_NAME=YOUR_CLOUDINARY_CLOUD_NAME
VITE_CLOUDINARY_UPLOAD_PRESET=YOUR_CLOUDINARY_UPLOAD_PRESET

# Cấu hình Cloudinary cho Security Exception (upload ảnh sự cố an ninh)
VITE_CLOUDINARY_CLOUD_NAME_EXCEPTIONS=YOUR_CLOUDINARY_CLOUD_NAME_EXCEPTIONS
VITE_CLOUDINARY_PRESET_EXCEPTIONS=YOUR_CLOUDINARY_PRESET_EXCEPTIONS

# Cấu hình Cloudinary cho Danh sách đen (Blacklist)
# Cần tạo Upload Preset (Unsigned) trong Cloudinary Console → Settings → Upload
VITE_CLOUDINARY_CLOUD_NAME_BLACKLIST=YOUR_CLOUDINARY_CLOUD_NAME_BLACKLIST
VITE_CLOUDINARY_PRESET_BLACKLIST=YOUR_CLOUDINARY_PRESET_BLACKLIST

# Plate Recognizer API Token
# Lấy từ: https://platerecognizer.com/ → Dashboard → API Token
# ⚠️ QUAN TRỌNG: Token cũ đã bị lộ trên GitHub public → cần tạo token mới tại platerecognizer.com
VITE_PLATE_RECOGNIZER_TOKEN=YOUR_PLATE_RECOGNIZER_TOKEN